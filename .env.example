# ── Streamline Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32_to_generate

# Shared secret between backend and bot
# Generate with: openssl rand -hex 16
BOT_SECRET=CHANGE_ME_use_openssl_rand_hex_16_to_generate

# ── Network ───────────────────────────────────────────────────────────────────
HOST_PORT=7878
ALLOWED_ORIGINS=http://localhost:7878

# ── Telegram Bot (optional) ───────────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_TOKEN=

# Restrict bot to a single chat (get via @userinfobot). Leave empty for no restriction.
TELEGRAM_CHAT_ID=

# Bot login credentials (create a dedicated user in Streamline settings)
STREAMLINE_BOT_USER=bot
STREAMLINE_BOT_PASS=CHANGE_ME_bot_password

# ── Discord Webhook (optional) ────────────────────────────────────────────────
# Create in Discord: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# ── Misc ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
